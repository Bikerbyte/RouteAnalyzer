<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Route Analyzer converts ping and tracert output into an operator-friendly network path report." />
    <title>@ViewData["Title"] - Route Analyzer</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RouteAnalyzer.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container shell-bar">
            <a class="brand-mark" asp-area="" asp-page="/Index">
                <span class="brand-dot" aria-hidden="true"></span>
                <span class="brand-copy">
                    <strong>Route Analyzer</strong>
                    <span>Network Path Observability Demo</span>
                </span>
            </a>
            <nav class="shell-nav" aria-label="Primary navigation">
                <a asp-area="" asp-page="/Index">Diagnostics</a>
                <a asp-area="" asp-page="/Privacy">Project Notes</a>
                <a href="/healthz" target="_blank" rel="noreferrer">/healthz</a>
            </nav>
        </div>
    </header>

    <div class="container shell-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container footer-inner">
            <span>Built with .NET 10, Razor Pages, and an operator-first mindset.</span>
            <div class="footer-links">
                <a asp-area="" asp-page="/Index">Diagnostics</a>
                <a asp-area="" asp-page="/Privacy">Notes</a>
                <a href="/healthz" target="_blank" rel="noreferrer">Health</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
