@page
@model IndexModel
@{
    ViewData["Title"] = "網路路徑分析";
}

<section class="hero-panel">
    <div class="hero-copy">
        <p class="eyebrow">Route Analyzer</p>
        <h1>Network route diagnostics for unstable latency.</h1>
        <p class="hero-text">
            輸入目標主機後，系統會執行 <code>ping</code> 與 <code>tracert</code>，
            協助你快速判斷延遲是否從某一跳開始明顯升高，並補上該 hop 所在網段類型、PTR 與地理資訊。
        </p>
    </div>
    <div class="hero-note">
        <span>Current scope</span>
        <strong>Windows host diagnostics, focused on single-run route analysis</strong>
    </div>
</section>

<section class="layout-grid">
    <div class="panel control-panel">
        <h2>Run analysis</h2>
        <p>支援輸入完整網址、網域或 IP。若輸入網址，系統會自動取 host 後再做 ping / tracert。</p>

        <form method="post" id="analyze-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <label asp-for="TargetHost" class="field-label">目標主機</label>
            <input asp-for="TargetHost" class="text-input" placeholder="例如 1.1.1.1 或 https://example.com/path" />

            <label asp-for="PingCount" class="field-label">Ping 次數</label>
            <input asp-for="PingCount" class="text-input" type="number" min="3" max="10" />

            <div class="action-row">
                <button type="submit" class="btn-check" id="analyze-button">
                    <span class="btn-text">開始分析</span>
                    <span class="btn-loading" aria-hidden="true">分析中...</span>
                </button>
            </div>

            <div class="submit-status" id="submit-status" aria-live="polite">
                正在執行 ping 與 tracert，請稍候。
            </div>
        </form>
    </div>

    <div class="panel summary-panel">
        <div class="summary-head">
            <h2>Summary</h2>
            @if (Model.Report is not null)
            {
                <span>@Model.Report.TargetHost</span>
            }
        </div>

        @if (Model.Report is null)
        {
            <div class="empty-state">
                <p>尚未執行分析。填入目標主機後按下開始分析。</p>
            </div>
        }
        else
        {
            <div class="summary-grid">
                <article class="metric-card">
                    <span class="metric-label">Average ping</span>
                    <strong>@(Model.Report.PingSummary.AverageRoundTripMs?.ToString() ?? "-") ms</strong>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Packet loss</span>
                    <strong>@Model.Report.PingSummary.PacketLossPercent%</strong>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Max hop latency</span>
                    <strong>@(Model.Report.Hops.Where(static hop => hop.AverageLatencyMs.HasValue).Select(static hop => hop.AverageLatencyMs!.Value).DefaultIfEmpty().Max()) ms</strong>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Likely bottleneck</span>
                    <strong>@(Model.Report.SuspectedIssue ?? "未觀察到明顯瓶頸")</strong>
                </article>
            </div>

            <p class="summary-text">@Model.Report.Narrative</p>
        }
    </div>
</section>

<section class="panel route-panel">
    <div class="summary-head">
        <h2>Route views</h2>
        @if (Model.Report is not null)
        {
            <span>@Model.Report.Hops.Count 跳</span>
        }
    </div>

    <div class="view-tabs" role="tablist" aria-label="Route views">
        <button type="button" class="view-tab is-active" data-view-target="timeline-view">Hop timeline</button>
        <button type="button" class="view-tab" data-view-target="map-view">Route map</button>
    </div>

    @if (Model.Report is null || Model.Report.Hops.Count == 0)
    {
        <div class="empty-state">
            <p>目前沒有 hop 資料。</p>
        </div>
    }
    else
    {
        <div class="route-view is-active" id="timeline-view">
            <div class="hop-list">
                @foreach (var hop in Model.Report.Hops)
                {
                    <article class="@Model.GetHopClass(hop)">
                        <div class="hop-main">
                            <div class="hop-id">
                                <span class="hop-index">@hop.HopNumber</span>
                                <div>
                                    <div class="hop-headline">
                                        <h3>@hop.DisplayAddress</h3>
                                        <span class="hop-badge">@hop.ScopeLabel</span>
                                    </div>
                                    <p>@hop.ScopeDetail</p>
                                    @if (!string.IsNullOrWhiteSpace(hop.ReverseDns))
                                    {
                                        <p class="hop-subline">PTR: @hop.ReverseDns</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Summary))
                                    {
                                        <p class="hop-subline">Location: @hop.GeoDetails!.Summary</p>
                                    }
                                    else if (!hop.IsTimeout && hop.ScopeLabel is "Public hop" or "Transit hop" or "Access / ISP edge")
                                    {
                                        <p class="hop-subline">Location: lookup unavailable</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Isp) || !string.IsNullOrWhiteSpace(hop.GeoDetails?.Asn))
                                    {
                                        <p class="hop-subline">Network: @hop.GeoDetails?.Isp @(string.IsNullOrWhiteSpace(hop.GeoDetails?.Asn) ? "" : $"(AS{hop.GeoDetails?.Asn})")</p>
                                    }
                                    <p class="hop-subline">@hop.Note</p>
                                </div>
                            </div>
                            <div class="hop-metrics">
                                <strong>@(hop.AverageLatencyMs?.ToString() ?? "*") ms</strong>
                                <span>Δ @(hop.LatencyDeltaMs?.ToString() ?? "-") ms</span>
                                @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Timezone))
                                {
                                    <span>@hop.GeoDetails!.Timezone</span>
                                }
                                <span>@string.Join(" / ", hop.Samples)</span>
                            </div>
                        </div>
                        <div class="latency-bar">
                            <div class="latency-fill" style="width:@Model.GetBarWidth(hop)"></div>
                        </div>
                    </article>
                }
            </div>
        </div>

        <div class="route-view" id="map-view">
            <div class="route-map-track">
                @foreach (var hop in Model.Report.Hops.Where(static hop => !hop.IsTimeout))
                {
                    <article class="map-node @(hop.SuspectedSpike ? "map-node-spike" : string.Empty)">
                        <span class="map-hop">Hop @hop.HopNumber</span>
                        <strong>@hop.DisplayAddress</strong>
                        <span>@hop.ScopeLabel</span>
                        @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Summary))
                        {
                            <span>@hop.GeoDetails!.Summary</span>
                        }
                        else if (!string.IsNullOrWhiteSpace(hop.ReverseDns))
                        {
                            <span>@hop.ReverseDns</span>
                        }
                        else
                        {
                            <span>@hop.ScopeDetail</span>
                        }
                        <span>@(hop.AverageLatencyMs?.ToString() ?? "*") ms</span>
                    </article>
                }
            </div>
        </div>
    }
</section>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById("analyze-form");
            const button = document.getElementById("analyze-button");

            if (!form || !button) {
                return;
            }

            form.addEventListener("submit", () => {
                button.disabled = true;
                button.classList.add("is-loading");
                document.body.classList.add("is-submitting");
            });

            document.querySelectorAll("[data-view-target]").forEach((tab) => {
                tab.addEventListener("click", () => {
                    const target = tab.getAttribute("data-view-target");
                    document.querySelectorAll(".view-tab").forEach((item) => item.classList.remove("is-active"));
                    document.querySelectorAll(".route-view").forEach((panel) => panel.classList.remove("is-active"));
                    tab.classList.add("is-active");
                    document.getElementById(target)?.classList.add("is-active");
                });
            });
        })();
    </script>
}
