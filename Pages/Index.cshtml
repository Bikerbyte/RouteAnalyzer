@page
@model IndexModel
@{
    ViewData["Title"] = "Route Analyzer";
    var hasReport = Model.Report is not null;
}

<section class="hero-panel">
    <div class="hero-copy">
        <p class="eyebrow">Network Path Observability Workbench</p>
        <h1>Route Analyzer</h1>
        <p class="hero-text">
            Turn a single <code>ping</code> + <code>tracert</code> run into an operator-friendly network path report.
            This side project is intentionally positioned for infra, SRE, DevOps, and cloud-facing roles, so it highlights
            troubleshooting signals, exportable evidence, and a small but real operational surface.
        </p>
        <div class="hero-highlights">
            <span class="scope-tag">Incident-style summary</span>
            <span class="scope-tag">Geo and ASN enrichment</span>
            <span class="scope-tag">CSV / JSON export</span>
            <span class="scope-tag">/healthz endpoint</span>
        </div>
    </div>
    <aside class="hero-note">
        <span class="scope-title">What This Project Shows</span>
        <div class="capability-mini-grid">
            <article>
                <strong>Diagnostics UX</strong>
                <p>Readable path analysis instead of raw terminal output alone.</p>
            </article>
            <article>
                <strong>Platform Mindset</strong>
                <p>Config validation, response compression, and forwarded header support.</p>
            </article>
            <article>
                <strong>Portfolio Fit</strong>
                <p>A project story that maps cleanly to infra and cloud roles.</p>
            </article>
        </div>
    </aside>
</section>

<section class="capability-grid">
    <article class="capability-card">
        <span class="metric-label">Signal</span>
        <h2>Spot the likely fault domain faster</h2>
        <p>Surface packet loss, latency jumps, timeouts, and hop classification in one place.</p>
    </article>
    <article class="capability-card">
        <span class="metric-label">Context</span>
        <h2>Add PTR, geo, ASN, and ISP clues</h2>
        <p>Public hops are enriched to make the path easier to reason about during triage.</p>
    </article>
    <article class="capability-card">
        <span class="metric-label">Operations</span>
        <h2>Expose a small but intentional app surface</h2>
        <p>The app includes health checks, runtime metadata, safer input handling, and exportable artifacts.</p>
    </article>
</section>

<section class="layout-grid">
    <div class="panel control-panel">
        <div class="panel-heading">
            <h2>Run Analysis</h2>
            <span>Hostname, IP, or full URL</span>
        </div>
        <p>Paste a target directly, or use a sample below to demo the workflow quickly.</p>

        <div class="sample-row" aria-label="Sample targets">
            <button type="button" class="sample-chip" data-sample-target="1.1.1.1">1.1.1.1</button>
            <button type="button" class="sample-chip" data-sample-target="8.8.8.8">8.8.8.8</button>
            <button type="button" class="sample-chip" data-sample-target="github.com">github.com</button>
            <button type="button" class="sample-chip" data-sample-target="cloudflare.com">cloudflare.com</button>
        </div>

        <form method="post" id="analyze-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <label asp-for="TargetHost" class="field-label">Target</label>
            <input asp-for="TargetHost" class="text-input" placeholder="Example: 1.1.1.1 or https://example.com" />

            <label asp-for="PingCount" class="field-label">Ping Probes</label>
            <input asp-for="PingCount" class="text-input" type="number" min="3" max="10" />

            <div class="action-row">
                <button type="submit" class="btn-check" id="analyze-button">
                    <span class="btn-text">Analyze Route</span>
                    <span class="btn-loading" aria-hidden="true">Running...</span>
                </button>
            </div>

            <div class="submit-status" id="submit-status" aria-live="polite">
                Running ICMP probes and traceroute. This can take a little while depending on the path.
            </div>
        </form>

        @if (hasReport)
        {
            <div class="export-group">
                <form method="post" asp-page-handler="ExportJson">
                    <input type="hidden" asp-for="TargetHost" />
                    <input type="hidden" asp-for="PingCount" />
                    <button type="submit" class="btn-secondary">Export JSON</button>
                </form>
                <form method="post" asp-page-handler="ExportCsv">
                    <input type="hidden" asp-for="TargetHost" />
                    <input type="hidden" asp-for="PingCount" />
                    <button type="submit" class="btn-secondary">Export CSV</button>
                </form>
            </div>
        }
    </div>

    <div class="panel summary-panel">
        <div class="summary-head">
            <h2>Executive Summary</h2>
            @if (hasReport)
            {
                <span>Target: @Model.Report!.TargetHost</span>
            }
        </div>

        @if (!hasReport)
        {
            <div class="empty-state">
                <p>
                    Run a diagnostic to generate an operator-style summary, route timeline, path map, and raw traceroute evidence.
                </p>
            </div>
        }
        else
        {
            <div class="status-row">
                <span class="@Model.GetStatusClass()">@Model.Report!.StatusLabel</span>
                <p>@Model.Report.StatusSummary</p>
            </div>

            <div class="summary-grid">
                <article class="metric-card">
                    <span class="metric-label">Average latency</span>
                    <strong>@(Model.Report.PingSummary.AverageRoundTripMs?.ToString() ?? "-") ms</strong>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Packet loss</span>
                    <strong>@Model.Report.PingSummary.PacketLossPercent%</strong>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Jitter</span>
                    <strong>@Model.JitterDisplay</strong>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Geo coverage</span>
                    <strong>@Model.GeoCoverageDisplay</strong>
                </article>
            </div>

            <p class="summary-text">@Model.Report.Narrative</p>

            <div class="meta-grid">
                <article class="meta-card">
                    <span class="metric-label">Execution ID</span>
                    <strong>@Model.Report.ExecutionId</strong>
                </article>
                <article class="meta-card">
                    <span class="metric-label">Generated</span>
                    <strong>@Model.GeneratedAtDisplay</strong>
                </article>
                <article class="meta-card">
                    <span class="metric-label">Duration</span>
                    <strong>@Model.Report.DurationMs ms</strong>
                </article>
                <article class="meta-card">
                    <span class="metric-label">Ping range</span>
                    <strong>@Model.PingRangeDisplay</strong>
                </article>
                <article class="meta-card meta-card-wide">
                    <span class="metric-label">Runtime</span>
                    <strong>@Model.Report.RuntimeSummary</strong>
                </article>
                <article class="meta-card meta-card-wide">
                    <span class="metric-label">Mode</span>
                    <strong>@Model.Report.DiagnosticMode</strong>
                </article>
            </div>
        }
    </div>
</section>

@if (hasReport)
{
    <section class="panel diagnostics-panel">
        <div class="summary-head">
            <h2>Evidence & Metadata</h2>
            <span>Generated after each run</span>
        </div>

        <div class="diagnostics-grid diagnostics-grid-six">
            <article class="diagnostic-card">
                <span class="metric-label">Success rate</span>
                <strong>@Model.Report!.PingSummary.SuccessRatePercent%</strong>
                <p>Successful ICMP replies across all configured ping probes.</p>
            </article>
            <article class="diagnostic-card">
                <span class="metric-label">Timeout hops</span>
                <strong>@Model.TimeoutCount</strong>
                <p>Hops that did not answer ICMP during the traceroute run.</p>
            </article>
            <article class="diagnostic-card">
                <span class="metric-label">Latency spikes</span>
                <strong>@Model.SpikeCount</strong>
                <p>Hops where latency increases sharply compared with the previous hop.</p>
            </article>
            <article class="diagnostic-card">
                <span class="metric-label">Public hops</span>
                <strong>@Model.PublicHopCount</strong>
                <p>Reachable hops classified as public, transit, ISP edge, or destination.</p>
            </article>
            <article class="diagnostic-card">
                <span class="metric-label">Geo misses</span>
                <strong>@Model.GeoLookupMissCount</strong>
                <p>Public hops that did not return geo data from the enrichment provider.</p>
            </article>
            <article class="diagnostic-card">
                <span class="metric-label">Geo provider</span>
                <strong>@Model.Report.GeoDataProvider</strong>
                <p>External data source used to enrich public IP hops with location context.</p>
            </article>
        </div>
    </section>
}

<section class="panel ops-panel">
    <div class="summary-head">
        <h2>Why This Reads Well For Infra / SRE / Cloud Roles</h2>
        <span>Operator-focused product choices</span>
    </div>

    <div class="ops-grid">
        <article class="ops-card">
            <h3>Operational Surface</h3>
            <p>
                The host is configured with response compression, forwarded header handling, startup config validation,
                and a JSON health endpoint at <a class="inline-link" href="/healthz" target="_blank" rel="noreferrer">/healthz</a>.
            </p>
        </article>
        <article class="ops-card">
            <h3>Diagnostics Story</h3>
            <p>
                Instead of dumping command output, the app frames results as a triage artifact: status level, likely issue,
                supporting metrics, and raw evidence for follow-up.
            </p>
        </article>
        <article class="ops-card">
            <h3>Portfolio Positioning</h3>
            <p>
                This project is intentionally more aligned with observability and troubleshooting than typical CRUD portfolio apps,
                which makes the GitHub story stronger for platform-focused roles.
            </p>
        </article>
    </div>
</section>

<section class="panel route-panel">
    <div class="summary-head">
        <h2>Route Views</h2>
        @if (hasReport)
        {
            <span>@Model.Report!.Hops.Count hops</span>
        }
    </div>

    <div class="view-tabs" role="tablist" aria-label="Route views">
        <button type="button" class="view-tab is-active" data-view-target="timeline-view" aria-selected="true">Hop Timeline</button>
        <button type="button" class="view-tab" data-view-target="map-view" aria-selected="false">Path Map</button>
        <button type="button" class="view-tab" data-view-target="raw-view" aria-selected="false">Raw Output</button>
    </div>

    @if (!hasReport || Model.Report!.Hops.Count == 0)
    {
        <div class="empty-state">
            <p>No hop data is available yet.</p>
        </div>
    }
    else
    {
        <div class="route-view is-active" id="timeline-view">
            <div class="hop-list">
                @foreach (var hop in Model.Report.Hops)
                {
                    <article class="@Model.GetHopClass(hop)">
                        <div class="hop-main">
                            <div class="hop-id">
                                <span class="hop-index">@hop.HopNumber</span>
                                <div>
                                    <div class="hop-headline">
                                        <h3>@hop.DisplayAddress</h3>
                                        <span class="hop-badge">@hop.ScopeLabel</span>
                                    </div>
                                    @if (string.IsNullOrWhiteSpace(hop.ReverseDns) || !hop.ScopeDetail.Contains(hop.ReverseDns, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <p>@hop.ScopeDetail</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hop.ReverseDns))
                                    {
                                        <p class="hop-subline">PTR: @hop.ReverseDns</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Summary))
                                    {
                                        <p class="hop-subline">Location: @hop.GeoDetails!.Summary</p>
                                    }
                                    else if (!hop.IsTimeout && hop.ScopeLabel is "Public hop" or "Transit hop" or "Access / ISP edge")
                                    {
                                        <p class="hop-subline">Location: enrichment unavailable</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Isp) || !string.IsNullOrWhiteSpace(hop.GeoDetails?.Asn))
                                    {
                                        <p class="hop-subline">Network: @hop.GeoDetails?.Isp @(string.IsNullOrWhiteSpace(hop.GeoDetails?.Asn) ? "" : $"(AS{hop.GeoDetails?.Asn})")</p>
                                    }
                                    @if (hop.GeoDetails is not null)
                                    {
                                        <div class="hop-tags">
                                            @if (!string.IsNullOrWhiteSpace(hop.GeoDetails.Isp))
                                            {
                                                <span class="hop-tag">ISP: @hop.GeoDetails.Isp</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(hop.GeoDetails.Asn))
                                            {
                                                <span class="hop-tag">ASN: AS@hop.GeoDetails.Asn</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(hop.GeoDetails.Organization) && !string.Equals(hop.GeoDetails.Organization, hop.GeoDetails.Isp, StringComparison.OrdinalIgnoreCase))
                                            {
                                                <span class="hop-tag">Org: @hop.GeoDetails.Organization</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(hop.GeoDetails.Timezone))
                                            {
                                                <span class="hop-tag">TZ: @hop.GeoDetails.Timezone</span>
                                            }
                                        </div>
                                    }
                                    <p class="hop-subline">@hop.Note</p>
                                </div>
                            </div>
                            <div class="hop-metrics">
                                <strong>@(hop.AverageLatencyMs?.ToString() ?? "*") ms</strong>
                                <span>Delta: @(hop.LatencyDeltaMs?.ToString() ?? "-") ms</span>
                                @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Timezone))
                                {
                                    <span>@hop.GeoDetails!.Timezone</span>
                                }
                                <span>@string.Join(" / ", hop.Samples)</span>
                            </div>
                        </div>
                        <div class="latency-bar">
                            <div class="latency-fill" style="width:@Model.GetBarWidth(hop)"></div>
                        </div>
                    </article>
                }
            </div>
        </div>

        <div class="route-view" id="map-view">
            @{
                var mapHops = Model.Report.Hops.Where(static hop => !hop.IsTimeout).ToList();
            }
            <div class="map-metrics">
                <article class="map-metric">
                    <span class="metric-label">Public hops</span>
                    <strong>@Model.PublicHopCount</strong>
                </article>
                <article class="map-metric">
                    <span class="metric-label">Geocoded hops</span>
                    <strong>@Model.CoordinateHopCount</strong>
                </article>
                <article class="map-metric">
                    <span class="metric-label">Geo misses</span>
                    <strong>@Model.GeoLookupMissCount</strong>
                </article>
            </div>

            <div class="map-legend" aria-label="Map legend">
                <span class="legend-item"><i class="legend-dot legend-dot-private"></i>Private network</span>
                <span class="legend-item"><i class="legend-dot legend-dot-public"></i>Public path</span>
                <span class="legend-item"><i class="legend-dot legend-dot-spike"></i>Latency spike</span>
                <span class="legend-item"><i class="legend-dot legend-dot-missing"></i>Missing geo</span>
            </div>

            @if (Model.CoordinateHopCount == 0)
            {
                <p class="map-note">No public hop returned coordinates, so this view falls back to a staged route layout rather than geographic placement.</p>
            }

            <div class="geo-map-canvas">
                <div class="geo-map-grid"></div>
                <svg class="map-overlay" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                    @for (var index = 1; index < mapHops.Count; index++)
                    {
                        var previousHop = mapHops[index - 1];
                        var currentHop = mapHops[index];
                        <line class="@Model.GetMapLineClass(previousHop, currentHop)"
                              x1="@Model.GetGeoXValue(previousHop).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                              y1="@Model.GetGeoYValue(previousHop).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                              x2="@Model.GetGeoXValue(currentHop).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                              y2="@Model.GetGeoYValue(currentHop).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                    }
                </svg>

                @foreach (var hop in mapHops)
                {
                    <article class="@Model.GetMapNodeClass(hop)" style="left:@Model.GetGeoX(hop); top:@Model.GetGeoY(hop);">
                        <span class="map-hop">Hop @hop.HopNumber</span>
                        <strong>@hop.DisplayAddress</strong>
                        <span>@hop.ScopeLabel</span>
                        @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Summary))
                        {
                            <span>@hop.GeoDetails!.Summary</span>
                        }
                        else if (!string.IsNullOrWhiteSpace(hop.ReverseDns))
                        {
                            <span>@hop.ReverseDns</span>
                        }
                        else
                        {
                            <span>@hop.ScopeDetail</span>
                        }
                        <div class="map-node-meta">
                            @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Isp))
                            {
                                <span>@hop.GeoDetails!.Isp</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Asn))
                            {
                                <span>AS@hop.GeoDetails!.Asn</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(hop.GeoDetails?.Timezone))
                            {
                                <span>@hop.GeoDetails!.Timezone</span>
                            }
                        </div>
                        <span>@(hop.AverageLatencyMs?.ToString() ?? "*") ms</span>
                    </article>
                }
            </div>
        </div>

        <div class="route-view" id="raw-view">
            <div class="raw-panel">
                <div class="raw-summary">
                    <span>Ping avg: @(Model.Report.PingSummary.AverageRoundTripMs?.ToString() ?? "-") ms</span>
                    <span>Loss: @Model.Report.PingSummary.PacketLossPercent%</span>
                    <span>Success: @Model.Report.PingSummary.SuccessRatePercent%</span>
                    <span>Hops: @Model.Report.Hops.Count</span>
                </div>
                <pre class="raw-output">@string.Join(Environment.NewLine, Model.Report.RawTracerouteLines)</pre>
            </div>
        </div>
    }
</section>
